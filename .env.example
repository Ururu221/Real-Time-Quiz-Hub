# Copy this file to ".env" and replace the placeholder values before running
# `docker compose up`. The .env file is read automatically by docker compose.

# --- PostgreSQL ---
POSTGRES_DB=quizhub
POSTGRES_USER=quizhub_user
POSTGRES_PASSWORD=change_me

# --- Application ---
# Must be at least 32 characters (used as the HMAC key for signing JWTs).
JWT_SECRET=change_me_min_32_chars
